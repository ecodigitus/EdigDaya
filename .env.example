# =================== Claude AI (Anthropic) ===================
# Ambil API key di https://console.anthropic.com  (Settings > API Keys)
# Boleh dikosongkan dulu -> bot tetap jalan mode rule-based (menu) tanpa AI.
ANTHROPIC_API_KEY=

# Model Claude yang dipakai. Ganti sesuai kebutuhan biaya vs kualitas:
#   claude-opus-4-8    -> paling pintar   (~$5 / $25 per 1 juta token)
#   claude-sonnet-4-6  -> seimbang        (~$3 / $15 per 1 juta token)
#   claude-haiku-4-5   -> tercepat+termurah (~$1 / $5 per 1 juta token)  << rekomendasi buat CS bot
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

# =================== WhatsApp (Baileys) ===================
# Folder penyimpanan sesi login WA (hasil scan QR). Sudah masuk .gitignore.
WA_AUTH_DIR=auth
# Balas pesan grup juga? (default: false, cuma chat pribadi)
WA_HANDLE_GROUPS=false

# =================== Fitur Campaign (proaktif) ===================
# Nomor admin yang boleh memicu broadcast (format 62..., pisah koma). Kosong = fitur push nonaktif.
ADMIN_NUMBERS=
# Nomor tujuan broadcast demo — nomor asli yang kamu kontrol untuk uji "push".
# Contoh: BROADCAST_TARGETS=6281234567890,6289876543210
BROADCAST_TARGETS=

# =================== Batas & Keamanan ===================
# Panjang maksimum pesan masuk yang diproses (anti-abuse)
MAX_INBOUND_CHARS=2000
# Maksimum pesan per user per menit (rate limit, anti-spam & hemat biaya AI)
RATE_MAX_PER_MIN=15
# Berapa giliran percakapan (user+bot) yang diingat per user
HISTORY_TURNS=6
# Sesi user dianggap kadaluarsa setelah tidak aktif sekian menit
SESSION_TTL_MINUTES=60

# =================== Logging ===================
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
