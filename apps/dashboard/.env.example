# =====================================================================
#  edig-dashboard — contoh konfigurasi (.env)
#  Salin jadi `.env` lalu isi. JANGAN commit `.env` (OWASP A05).
#  Hanya PLACEHOLDER — tak ada secret asli di sini.
# =====================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- DB mirror (Cloud SQL) — akun READ-ONLY peserta (WAJIB) ---
# Host/DB Cloud SQL yang sama dg bot (tabel tim edig_dev_* + 27 tabel nasional RO).
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Akun aplikasi least-privilege (Fase B) ---
# Kalau diisi, runtime pakai ini (tulis hanya edig_dev_*); kalau kosong -> fallback read-only.
APP_DB_USERNAME=
APP_DB_PASSWORD=

# --- Akun admin (HANYA untuk scripts/mirror-migrate*.ts, tak dipakai runtime) ---
ADMIN_DB_USERNAME=
ADMIN_DB_PASSWORD=

# --- Prefix tabel tim: TEAM_NAME "edig_dev" -> prefix "edig_dev_" ---
TEAM_NAME=edig_dev

# --- Secret HMAC untuk tanda tangan token sesi (WAJIB di produksi) ---
# Buat acak, mis: openssl rand -hex 32
SESSION_SECRET=

# --- Supabase (LEGACY, opsional) — kosongkan untuk deploy baru ---
SUPABASE_DB_URL=
